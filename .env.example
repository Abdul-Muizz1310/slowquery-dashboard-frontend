# ---------------------------------------------------------------------------
# slowquery-dashboard-frontend — environment variables
# ---------------------------------------------------------------------------
# Every NEXT_PUBLIC_* variable is parsed at boot by `src/lib/env.ts` (added
# in S4). Missing values throw at import time so misconfigured builds fail
# fast rather than producing a half-broken dashboard in production.

# --- Backend ---------------------------------------------------------------
# Base URL of the slowquery-demo-backend Render service. The dashboard reads
# /_slowquery/queries, /_slowquery/queries/{id}, /_slowquery/api/stream, and
# /branches/switch through this host.
NEXT_PUBLIC_API_URL=https://slowquery-demo-backend.onrender.com

# --- Site ------------------------------------------------------------------
# Absolute origin this deployment serves itself on. Used by Playwright and
# by Next.js for absolute URL generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
